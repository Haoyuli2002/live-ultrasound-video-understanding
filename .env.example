# Copy this file to `.env` and fill in your real keys.
# `.env` is gitignored; `.env.example` is safe to commit.
#
# These are auto-loaded by scripts/_env_loader.py — no need to `export`.

# OpenAI — used by:
#   Step 4  : llm_segmentation.py        (GPT-4o cut verification)
#   Step 5a : qa_generation.py           (GPT-4o Vision, offline QA)
#   Step 5b : streaming_qa_generation.py (GPT-4o Vision oracle, streaming QA)
OPENAI_API_KEY=sk-proj-...

# OpenRouter — used by:
#   Step 5c : qa_validator.py            (Gemini 2.5 Flash, cross-family validator)
OPENROUTER_API_KEY=sk-or-v1-...

# Google AI Studio — used by (planned migration):
#   Step 5b/5c : direct video-clip input to Gemini 2.5 Flash (replaces frame sampling)
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
